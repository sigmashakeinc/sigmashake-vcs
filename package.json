{
  "name": "sigmashake-vcs",
  "private": true,
  "bin": {
    "sigmashake-vcs": "tools/vcs-cli.ts"
  },
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "test": "bun test",
    "clean": "node -e \"const fs=require('node:fs');for(const d of ['dist','.wrangler'])try{fs.rmSync(d,{recursive:true,force:true})}catch(_){}\"",
    "lint": "biome check .",
    "fix": "biome check --write .",
    "test:integration": "bun test test/integration",
    "test:e2e": "bun test test/e2e",
    "test:api": "bun test test/api",
    "test:configuration": "bun test test/configuration",
    "test:sast": "bun test test/sast",
    "test:audit": "bun test test/dependencies",
    "test:component": "bun test test/component/",
    "test:regression": "bun test test/regression/",
    "test:load": "bun test test/load/",
    "test:stress": "bun test test/stress/",
    "test:spike": "bun test test/spike/",
    "test:soak": "bun test test/soak/",
    "test:scale": "bun test test/scalability/",
    "test:chaos": "bun test test/chaos/",
    "test:failover": "bun test test/failover/",
    "test:dast": "bun test test/dast/",
    "test:pen": "bun test test/pen/"
  },
  "dependencies": {
    "hono": "^4.7.7"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@cloudflare/workers-types": "^4.20250620.0",
    "bun-types": "^1.3.13",
    "typescript": "^5.8.3",
    "wrangler": "^4.87.0"
  }
}
